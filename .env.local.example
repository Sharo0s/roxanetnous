# Supabase
# REQUIRED prod ET preview (assertion ! runtime dans lib/supabase/*.ts -> crash si absente).
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
# REQUIRED prod : adresse expediteur (sans : fallback sandbox onboarding@resend.dev -> bounces massifs).
RESEND_FROM_EMAIL=your_resend_from_email
# Destinataire des notifications admin (anti-fraude parrainage, alertes systeme)
ADMIN_NOTIFICATIONS_EMAIL=contact@roxanetnous.fr

# Cron Secret (Vercel)
CRON_SECRET=your_random_secret

# Encryption
ENCRYPTION_KEY=your_32_byte_hex_key

# HMAC liens opt-out emails de rappel (>=32 chars). Generer avec : `openssl rand -hex 32`.
OPTOUT_TOKEN_SECRET=your_random_64_hex_secret

# Parrainage : secret partage entre le webhook Stripe et le helper
# revokeFilleuleValidationFromWebhook (auth guard, evite l'exposition
# de la server action a tout client authentifie). Generer avec :
# `openssl rand -hex 32`
PARRAINAGE_INTERNAL_SECRET=your_random_64_hex_secret

# Sentry (alerting erreurs prod, story 4.1)
# DSN expose au client (capture exceptions browser). Peut etre identique au DSN serveur.
NEXT_PUBLIC_SENTRY_DSN=
# DSN server-side (capture exceptions Node.js + Edge runtime).
SENTRY_DSN=
# Slug organisation Sentry (ex: roxanetnous). Lu par withSentryConfig au build.
SENTRY_ORG=
# Slug projet Sentry (ex: roxanetnous-web). Lu par withSentryConfig au build.
SENTRY_PROJECT=
# REQUIRED prod : token upload sourcemaps build-time (scope: project:releases).
# Generer dans Sentry > Settings > Auth Tokens. Lu par withSentryConfig
# uniquement au build, JAMAIS au runtime. Sans, sourcemaps non uploadees
# (silencieux, build OK : les stack traces Sentry resteront minifiees).
SENTRY_AUTH_TOKEN=

# Sel HMAC pour hash rate-limit Sentry (story 4.1 review D3). Sans, le
# hashRateLimitKey degrade en SHA-256 non-sale (l'IP reste reversible par
# precomputation IPv4). Generer avec : `openssl rand -hex 32`.
RATE_LIMIT_HASH_SALT=your_random_64_hex_secret

# Toutes les vars marquees "REQUIRED prod" sont verifiees par check-required-env.mjs
# (exit 1 build Vercel si manquante, shape invalide ou valeur placeholder your_*).

# SKIP_E2E_TESTS=true  # Optionnel preview/dev. INTERDIT en VERCEL_ENV=production (check:env exit 1).
