    "@types/react": "^19.2.13",
    "@vercel/functions": "^3.5.0",
    "@workflow/next": "^4.0.5",
    "autoprefixer": "^10.4.24",
    "leaflet": "^1.9.4",
    "next": "^16.1.6",
    "postcss": "^8.5.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "resend": "^6.9.2",
    "stripe": "^22.1.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.3",
    "workflow": "^4.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/leaflet": "^1.9.21",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-core": "^4.11.4",
    "eslint": "^10.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "undici": "^7.24.0",
    "devalue": "^5.6.4",
    "postcss": "$postcss",
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    }
  }
}
